<UserControl
    x:Class="CredBench.Windows.Views.CardDetails.PkocDetailsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:CredBench.Core.ViewModels;assembly=Core"
    xmlns:guidelinesConverters="clr-namespace:ZBitSystems.Wpf.UI.Converters;assembly=ZBitSystems.Wpf.UI"
    xmlns:localization="clr-namespace:ZBitSystems.Wpf.UI.Localization;assembly=ZBitSystems.Wpf.UI"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewmodels:PkocViewModel}">

    <UserControl.Resources>
        <guidelinesConverters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <guidelinesConverters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource Padding.Card}">

            <!-- ═══════════════════════════════════════════ -->
            <!-- Credential Section (when PKOC detected)    -->
            <!-- ═══════════════════════════════════════════ -->
            <StackPanel Visibility="{Binding HasDetectedCredential, Converter={StaticResource BoolToVisibility}}">

                <!-- Card Info -->
                <Grid Margin="{StaticResource Margin.Section}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{StaticResource Gutter.Medium}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource Field.Label}"
                        Text="{localization:Localize PKOC_ProtocolVersion}"
                        TextAlignment="Right" />
                    <TextBlock Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource Field.Value}"
                        Text="{Binding DetectedDetails.ProtocolVersion, FallbackValue='N/A'}"
                        FontFamily="Consolas"
                        FontWeight="Medium" />

                    <TextBlock Grid.Row="1" Grid.Column="0"
                        Style="{StaticResource Field.Label}"
                        Text="{localization:Localize PKOC_SignatureValidation}"
                        TextAlignment="Right"
                        Margin="0,4,0,0" />
                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,4,0,0">
                        <!-- Valid -->
                        <StackPanel Orientation="Horizontal"
                            Visibility="{Binding SignatureValidVisible, Converter={StaticResource BoolToVisibility}}">
                            <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                Foreground="{StaticResource Brush.Success}"
                                Margin="0,0,6,0" />
                            <TextBlock Text="{localization:Localize PKOC_SignatureValid}"
                                Foreground="{StaticResource Brush.Success}"
                                FontWeight="Medium" />
                        </StackPanel>
                        <!-- Invalid -->
                        <StackPanel Orientation="Horizontal"
                            Visibility="{Binding SignatureInvalidVisible, Converter={StaticResource BoolToVisibility}}">
                            <ui:SymbolIcon Symbol="DismissCircle24"
                                Foreground="{StaticResource Brush.Error}"
                                Margin="0,0,6,0" />
                            <TextBlock Text="{localization:Localize PKOC_SignatureInvalid}"
                                Foreground="{StaticResource Brush.Error}"
                                FontWeight="Medium" />
                        </StackPanel>
                        <!-- Not Available -->
                        <TextBlock
                            Text="{localization:Localize PKOC_SignatureNotAvailable}"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Visibility="{Binding SignatureNotAvailableVisible, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Grid>

                <!-- Credential Size Selector -->
                <TextBlock Text="{localization:Localize PKOC_Credential}"
                    Style="{StaticResource Section.Header}" />
                <ComboBox x:Name="BitSizeSelector"
                    Style="{StaticResource ComboBox.Standard}"
                    SelectedIndex="0"
                    Margin="0,0,0,12"
                    Width="280"
                    HorizontalAlignment="Left">
                    <ComboBoxItem Content="{localization:Localize PKOC_256BitOption}" />
                    <ComboBoxItem Content="{localization:Localize PKOC_75BitOption}" />
                    <ComboBoxItem Content="{localization:Localize PKOC_64BitOption}" />
                </ComboBox>

                <!-- 256-bit Credential -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=BitSizeSelector}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="{localization:Localize PKOC_Hex}"
                        Style="{StaticResource Field.Label}"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <TextBox Text="{Binding DetectedDetails.Credential256Hex, Mode=OneWay, FallbackValue='N/A'}"
                        Style="{StaticResource TextBox.Copyable}"
                        FontSize="10"
                        Margin="0,0,0,8" />

                    <TextBlock Text="{localization:Localize PKOC_WiegandBits256}"
                        Style="{StaticResource Field.Label}"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <TextBox Text="{Binding DetectedDetails.Credential256Bits, Mode=OneWay, FallbackValue='N/A'}"
                        Style="{StaticResource TextBox.Copyable}"
                        FontSize="10"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!-- 75-bit Credential -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=BitSizeSelector}" Value="1">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="{localization:Localize PKOC_Hex}"
                        Style="{StaticResource Field.Label}"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <TextBox Text="{Binding DetectedDetails.Credential75Hex, Mode=OneWay, FallbackValue='N/A'}"
                        Style="{StaticResource TextBox.Copyable}"
                        FontSize="10"
                        Margin="0,0,0,8" />

                    <TextBlock Text="{localization:Localize PKOC_WiegandBits75}"
                        Style="{StaticResource Field.Label}"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <TextBox Text="{Binding DetectedDetails.Credential75Bits, Mode=OneWay, FallbackValue='N/A'}"
                        Style="{StaticResource TextBox.Copyable}"
                        FontSize="10" />
                </StackPanel>

                <!-- 64-bit Credential -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=BitSizeSelector}" Value="2">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="{localization:Localize PKOC_Hex}"
                        Style="{StaticResource Field.Label}"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <TextBox Text="{Binding DetectedDetails.Credential64Hex, Mode=OneWay, FallbackValue='N/A'}"
                        Style="{StaticResource TextBox.Copyable}"
                        FontSize="10"
                        Margin="0,0,0,8" />

                    <TextBlock Text="{localization:Localize PKOC_WiegandBits64}"
                        Style="{StaticResource Field.Label}"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <TextBox Text="{Binding DetectedDetails.Credential64Bits, Mode=OneWay, FallbackValue='N/A'}"
                        Style="{StaticResource TextBox.Copyable}"
                        FontSize="10" />
                </StackPanel>

                <Separator Margin="0,16,0,8" />
            </StackPanel>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Card Programming Section                   -->
            <!-- ═══════════════════════════════════════════ -->
            <TextBlock Text="{localization:Localize PKOC_Programming_Header}"
                Style="{StaticResource Section.Header}" />

            <!-- GP Key Selection -->
            <StackPanel Margin="{StaticResource Margin.Section}">
                <RadioButton
                    Content="{localization:Localize PKOC_Programming_DefaultKey}"
                    GroupName="GpKey"
                    IsChecked="True"
                    Margin="0,0,0,4">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProgramming}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                <RadioButton
                    Content="{localization:Localize PKOC_Programming_CustomKey}"
                    GroupName="GpKey"
                    IsChecked="{Binding UseCustomKey}"
                    Margin="0,0,0,4">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProgramming}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>

                <!-- Custom Key Input -->
                <StackPanel
                    Margin="20,4,0,0"
                    Visibility="{Binding UseCustomKey, Converter={StaticResource BoolToVisibility}}">
                    <TextBox
                        x:Name="CustomKeyInput"
                        Text="{Binding CustomKeyHex, UpdateSourceTrigger=PropertyChanged}"
                        MaxLength="32"
                        CharacterCasing="Upper"
                        Width="300"
                        HorizontalAlignment="Left"
                        PreviewTextInput="CustomKeyInput_PreviewTextInput"
                        DataObject.Pasting="CustomKeyInput_Pasting">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBox.Standard}">
                                <Setter Property="FontFamily" Value="Consolas" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProgramming}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock
                        FontSize="{StaticResource FontSize.Caption}"
                        Margin="0,2,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding CustomKeyHex.Length, StringFormat='{}{0}/32 hex characters'}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CustomKeyHex.Length}" Value="32">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Program Button -->
            <ui:Button
                Content="{localization:Localize PKOC_Programming_ProgramButton}"
                Icon="{ui:SymbolIcon ArrowDownload24}"
                Command="{Binding ProgramCardCommand}"
                Appearance="Primary"
                Margin="0,8,0,0" />

            <!-- Progress Bar (shown during programming) -->
            <ProgressBar
                IsIndeterminate="True"
                Height="4"
                Margin="0,12,0,0"
                Visibility="{Binding IsProgramming, Converter={StaticResource BoolToVisibility}}" />

            <!-- Status Text -->
            <TextBlock
                Text="{Binding ProgrammingStatus}"
                Margin="0,8,0,0"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Visibility="{Binding ProgrammingStatus, Converter={StaticResource NullToVisibility}}" />

            <!-- Success Message -->
            <Border
                Margin="0,8,0,0"
                Padding="12,8"
                CornerRadius="{StaticResource CornerRadius.Small}"
                Background="{StaticResource Brush.Success}"
                Visibility="{Binding ProgrammingComplete, Converter={StaticResource BoolToVisibility}}">
                <TextBlock
                    Text="{localization:Localize PKOC_Programming_ScanToView}"
                    Foreground="White"
                    FontWeight="Medium" />
            </Border>

            <!-- Error Message -->
            <Border
                Margin="0,8,0,0"
                Padding="12,8"
                CornerRadius="{StaticResource CornerRadius.Small}"
                Background="{StaticResource Brush.Error}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                <StackPanel>
                    <TextBlock
                        Text="{Binding ErrorMessage}"
                        Foreground="White"
                        TextWrapping="Wrap" />
                    <ui:Button
                        Content="{localization:Localize PKOC_Programming_Dismiss}"
                        Command="{Binding DismissErrorCommand}"
                        Margin="0,4,0,0"
                        Appearance="Secondary" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
