<ui:FluentWindow
    x:Class="CredBench.Windows.Views.CardDetails.PkocProgramDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:CredBench.Core.ViewModels;assembly=Core"
    xmlns:guidelinesConverters="clr-namespace:ZBitSystems.Wpf.UI.Converters;assembly=ZBitSystems.Wpf.UI"
    xmlns:localization="clr-namespace:ZBitSystems.Wpf.UI.Localization;assembly=ZBitSystems.Wpf.UI"
    mc:Ignorable="d"
    Title="{localization:Localize PKOC_Programming_Header}"
    Width="460"
    Height="580"
    MinWidth="400"
    MinHeight="500"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    ExtendsContentIntoTitleBar="True"
    d:DataContext="{d:DesignInstance viewmodels:PkocViewModel}">

    <ui:FluentWindow.Resources>
        <guidelinesConverters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <guidelinesConverters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="{localization:Localize PKOC_Programming_Header}"
            ShowMaximize="False"
            ShowMinimize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,8,24,24">

            <!-- Card Info Section -->
            <TextBlock Text="{localization:Localize PKOC_CardInfo_Header}"
                Style="{StaticResource Section.Header}" />

            <StackPanel Margin="{StaticResource Margin.Section}">
                <!-- Query Progress -->
                <ProgressBar
                    IsIndeterminate="True"
                    Height="4"
                    Margin="0,0,0,8"
                    Visibility="{Binding IsQuerying, Converter={StaticResource BoolToVisibility}}" />

                <!-- Query Error -->
                <Border
                    Margin="0,0,0,8"
                    Padding="10,8"
                    CornerRadius="{StaticResource CornerRadius.Small}"
                    Background="{StaticResource Brush.Error}"
                    Visibility="{Binding QueryError, Converter={StaticResource NullToVisibility}}">
                    <StackPanel>
                        <TextBlock
                            Text="{Binding QueryError}"
                            Foreground="White"
                            TextWrapping="Wrap" />

                        <!-- Expandable diagnostic details -->
                        <StackPanel Visibility="{Binding QueryErrorDetails, Converter={StaticResource NullToVisibility}}">
                            <ui:Button
                                Command="{Binding ToggleQueryErrorDetailsCommand}"
                                Margin="0,6,0,0"
                                Appearance="Secondary"
                                Padding="8,2">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Content" Value="{localization:Localize PKOC_CardInfo_ShowDetails}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowQueryErrorDetails}" Value="True">
                                                <Setter Property="Content" Value="{localization:Localize PKOC_CardInfo_HideDetails}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                            <TextBlock
                                Text="{Binding QueryErrorDetails}"
                                Foreground="#FFCCCC"
                                TextWrapping="Wrap"
                                FontFamily="Consolas"
                                FontSize="{StaticResource FontSize.Caption}"
                                Margin="0,4,0,0"
                                Visibility="{Binding ShowQueryErrorDetails, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>

                        <ui:Button
                            Content="{localization:Localize PKOC_Programming_Dismiss}"
                            Command="{Binding DismissQueryErrorCommand}"
                            Margin="0,6,0,0"
                            Appearance="Secondary" />
                    </StackPanel>
                </Border>

                <!-- Card Content Results -->
                <StackPanel Visibility="{Binding HasCardContent, Converter={StaticResource BoolToVisibility}}">

                    <!-- Memory Info -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                        Visibility="{Binding CardContent.FreePersistentMemory, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Text="{localization:Localize PKOC_CardInfo_FreeMemory}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Margin="4,0,0,0">
                            <TextBlock.Text>
                                <Binding Path="CardContent.FreePersistentMemory" StringFormat="{}{0:N0} bytes" />
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- PKOC Status -->
                    <Border
                        Margin="0,4,0,4"
                        Padding="8,6"
                        CornerRadius="{StaticResource CornerRadius.Small}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CardContent.HasPkocApplet}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{localization:Localize PKOC_CardInfo_PkocNotInstalled}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CardContent.HasPkocApplet}" Value="True">
                                            <Setter Property="Text" Value="{localization:Localize PKOC_CardInfo_PkocInstalled}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="FontWeight" Value="Medium" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Installed Applets List -->
                    <TextBlock Text="{localization:Localize PKOC_CardInfo_Applets}"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,4,0,2"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <ItemsControl ItemsSource="{Binding CardContent.Applets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <TextBlock Text="{Binding AidHex}"
                                        FontFamily="Consolas"
                                        FontSize="{StaticResource FontSize.Caption}" />
                                    <TextBlock Text=" — " FontSize="{StaticResource FontSize.Caption}"
                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding LifecycleDescription}"
                                        FontSize="{StaticResource FontSize.Caption}"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Loaded Packages List -->
                    <TextBlock Text="{localization:Localize PKOC_CardInfo_Packages}"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,6,0,2"
                        FontSize="{StaticResource FontSize.Caption}" />
                    <ItemsControl ItemsSource="{Binding CardContent.Packages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <TextBlock Text="{Binding AidHex}"
                                        FontFamily="Consolas"
                                        FontSize="{StaticResource FontSize.Caption}" />
                                    <TextBlock Text=" — " FontSize="{StaticResource FontSize.Caption}"
                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding LifecycleDescription}"
                                        FontSize="{StaticResource FontSize.Caption}"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Refresh button (shown after initial query completes) -->
                <ui:Button
                    Content="{localization:Localize PKOC_CardInfo_RefreshButton}"
                    Icon="{ui:SymbolIcon ArrowSync24}"
                    Command="{Binding QueryCardContentCommand}"
                    Appearance="Secondary"
                    Margin="0,8,0,0">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQuerying}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsProgramming}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasCardContent}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding QueryError, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>

            <Separator Margin="0,8" />

            <!-- GP Key Selection -->
            <TextBlock Text="{localization:Localize PKOC_Programming_Header}"
                Style="{StaticResource Section.Header}" />

            <StackPanel Margin="{StaticResource Margin.Section}">
                <RadioButton
                    Content="{localization:Localize PKOC_Programming_DefaultKey}"
                    GroupName="GpKey"
                    IsChecked="True"
                    Margin="0,0,0,4">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProgramming}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                <RadioButton
                    Content="{localization:Localize PKOC_Programming_CustomKey}"
                    GroupName="GpKey"
                    IsChecked="{Binding UseCustomKey}"
                    Margin="0,0,0,4">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProgramming}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>

                <!-- Custom Key Input -->
                <StackPanel
                    Margin="20,4,0,0"
                    Visibility="{Binding UseCustomKey, Converter={StaticResource BoolToVisibility}}">
                    <TextBox
                        x:Name="CustomKeyInput"
                        Text="{Binding CustomKeyHex, UpdateSourceTrigger=PropertyChanged}"
                        MaxLength="32"
                        CharacterCasing="Upper"
                        Width="300"
                        HorizontalAlignment="Left"
                        PreviewTextInput="CustomKeyInput_PreviewTextInput"
                        DataObject.Pasting="CustomKeyInput_Pasting">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource TextBox.Standard}">
                                <Setter Property="FontFamily" Value="Consolas" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProgramming}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock
                        FontSize="{StaticResource FontSize.Caption}"
                        Margin="0,2,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding CustomKeyHex.Length, StringFormat='{}{0}/32 hex characters'}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CustomKeyHex.Length}" Value="32">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Program Button -->
            <ui:Button
                Content="{localization:Localize PKOC_Programming_ProgramButton}"
                Icon="{ui:SymbolIcon ArrowDownload24}"
                Command="{Binding ProgramCardCommand}"
                Appearance="Primary"
                Margin="0,8,0,0" />

            <!-- Progress Bar (shown during programming) -->
            <ProgressBar
                IsIndeterminate="True"
                Height="4"
                Margin="0,12,0,0"
                Visibility="{Binding IsProgramming, Converter={StaticResource BoolToVisibility}}" />

            <!-- Status Text -->
            <TextBlock
                Text="{Binding ProgrammingStatus}"
                Margin="0,8,0,0"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Visibility="{Binding ProgrammingStatus, Converter={StaticResource NullToVisibility}}" />

            <!-- Success Message -->
            <Border
                Margin="0,8,0,0"
                Padding="12,8"
                CornerRadius="{StaticResource CornerRadius.Small}"
                Background="{StaticResource Brush.Success}"
                Visibility="{Binding ProgrammingComplete, Converter={StaticResource BoolToVisibility}}">
                <TextBlock
                    Text="{localization:Localize PKOC_Programming_ScanToView}"
                    Foreground="White"
                    FontWeight="Medium" />
            </Border>

            <!-- Error Message -->
            <Border
                Margin="0,8,0,0"
                Padding="12,8"
                CornerRadius="{StaticResource CornerRadius.Small}"
                Background="{StaticResource Brush.Error}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                <StackPanel>
                    <TextBlock
                        Text="{Binding ErrorMessage}"
                        Foreground="White"
                        TextWrapping="Wrap" />
                    <ui:Button
                        Content="{localization:Localize PKOC_Programming_Dismiss}"
                        Command="{Binding DismissErrorCommand}"
                        Margin="0,4,0,0"
                        Appearance="Secondary" />
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
